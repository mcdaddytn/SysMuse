// IP-Port Schema v2
// Abstract Taxonomy Model with Portfolio Groups
// Created: 2026-03-28
//
// Key Changes from v1:
// - Abstract TaxonomyType/TaxonomyNode replaces hardcoded SuperSector/Sector/SubSector
// - PortfolioGroup for scoped analysis settings
// - ObjectClassification for multi-classification support
// - Generic level names (primaryLevel1, etc.) instead of hardcoded sector terminology
// - Includes unified scoring models that exist in DB but were missing from v1 schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS - CORE
// =============================================================================

enum AccessLevel {
  VIEWER
  ANALYST
  MANAGER
  ADMIN
}

enum CompetitorDiscoverySource {
  MANUAL
  CITATION_OVERLAP
  TERM_EXTRACTION
  LLM_SUGGESTED
  HYBRID_CLUSTER
}

enum PatentSource {
  CANDIDATES_FILE
  PATENTSVIEW_IMPORT
  MANUAL
  FAMILY_EXPANSION
}

enum WorkflowStatus {
  PENDING
  RUNNING
  COMPLETE
  ERROR
  CANCELLED
}

enum ScoreType {
  V2
  V3
  LLM
}

// =============================================================================
// ENUMS - TAXONOMY & CLASSIFICATION
// =============================================================================

enum TaxonomyRuleType {
  CPC_PREFIX // CPC code starts with expression
  CPC_SUBGROUP // Exact CPC subgroup match
  KEYWORD // Title/abstract contains keyword
  PHRASE // Exact phrase match
  KEYWORD_AND // All space-separated keywords must appear
  BOOLEAN // Complex boolean expression
}

enum TaxonomyRuleScope {
  GLOBAL // Universal rule (all portfolio groups)
  PORTFOLIO_GROUP // Portfolio-group-specific override
}

// =============================================================================
// ENUMS - PORTFOLIO GROUPS
// =============================================================================

enum PortfolioGroupTier {
  SCREENING // Large groups, standard settings (3 associations, standard LLM)
  STANDARD // Default tier
  ELITE // Small groups, enhanced settings (5+ associations, premium LLM)
  CUSTOM // Custom configuration
}

enum PortfolioGroupStatus {
  ACTIVE
  ARCHIVED
  RECALCULATING
}

enum RecalculationStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  FAILED
}

// =============================================================================
// ENUMS - UNIFIED SCORING
// =============================================================================

enum MetricAggregateScope {
  PORTFOLIO
  TAXONOMY_LEVEL1 // New name
  TAXONOMY_LEVEL2 // New name
  TAXONOMY_LEVEL3 // New name
  SUPER_SECTOR // Legacy - kept for migration
  SECTOR // Legacy - kept for migration
  SUB_SECTOR // Legacy - kept for migration
}

enum MetricLayer {
  BASE
  PORTFOLIO
  TAXONOMY_LEVEL1
  TAXONOMY_LEVEL2
  TAXONOMY_LEVEL3
  SUPER_SECTOR // Legacy - kept for migration
  SECTOR // Legacy - kept for migration
  SUB_SECTOR // Legacy - kept for migration
}

enum SnapshotScope {
  PORTFOLIO
  TAXONOMY_LEVEL1
  TAXONOMY_LEVEL2
  TAXONOMY_LEVEL3
  SUPER_SECTOR // Legacy - kept for migration
  SECTOR // Legacy - kept for migration
  SUB_SECTOR // Legacy - kept for migration
}

enum WeightProfileScope {
  GLOBAL
  TAXONOMY_LEVEL1
  TAXONOMY_LEVEL2
  TAXONOMY_LEVEL3
  PORTFOLIO
  SUPER_SECTOR // Legacy - kept for migration
  SECTOR // Legacy - kept for migration
  SUB_SECTOR // Legacy - kept for migration
}

// =============================================================================
// ENUMS - FOCUS AREAS
// =============================================================================

enum FocusGroupStatus {
  DRAFT
  NEEDS_REVIEW
  FORMALIZED
  ARCHIVED
}

enum FocusGroupSource {
  MANUAL
  GRID_FILTER
  LLM_SUGGESTION
  SEARCH_TERM
}

enum FocusAreaStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum SearchScopeType {
  PORTFOLIO
  TAXONOMY_LEVEL2 // New name
  TAXONOMY_LEVEL1 // New name
  COMPOUND
  PATENT_FAMILY
  SECTOR // Legacy - kept for migration
  SUPER_SECTOR // Legacy - kept for migration
}

enum MembershipType {
  SEARCH_MATCH
  MANUAL
  LLM_SUGGESTED
  INHERITED
}

enum SearchTermType {
  KEYWORD
  KEYWORD_AND
  PHRASE
  PROXIMITY
  WILDCARD
  BOOLEAN
}

enum SearchTermSource {
  MANUAL
  FREQUENCY_ANALYSIS
  PHRASE_HIGHLIGHT
  LLM_SUGGESTION
}

// =============================================================================
// ENUMS - FACETS & PROMPTS
// =============================================================================

enum FacetType {
  ATOMIC
  DERIVED
}

enum FacetDataType {
  NUMERIC
  CATEGORICAL
  TEXT
  BOOLEAN
}

enum NormalizationType {
  NONE
  MINMAX
  ZSCORE
  PERCENTILE
}

enum FacetExecutionStatus {
  PENDING
  RUNNING
  COMPLETE
  ERROR
}

enum PromptTemplateType {
  FREE_FORM
  STRUCTURED
}

enum PromptExecutionMode {
  PER_PATENT
  COLLECTIVE
}

enum PromptTemplateStatus {
  DRAFT
  RUNNING
  COMPLETE
  ERROR
}

// =============================================================================
// ENUMS - CPC (kept for backward compatibility)
// =============================================================================

enum CpcLevel {
  SECTION
  CLASS
  SUBCLASS
  GROUP
  SUBGROUP
}

enum CpcSource {
  XML
  EPO_API
  MANUAL
  LLM_INFERRED
}

// =============================================================================
// API & LLM CACHE
// =============================================================================

model ApiRequestCache {
  id           Int      @id @default(autoincrement())
  endpoint     String   @db.VarChar(50)
  requestType  String   @map("request_type") @db.VarChar(50)
  requestKey   String   @map("request_key") @db.VarChar(100)
  filePath     String   @map("file_path") @db.VarChar(255)
  fileSize     Int?     @map("file_size")
  statusCode   Int      @default(200) @map("status_code")
  errorMessage String?  @map("error_message") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([endpoint, requestType, requestKey])
  @@index([endpoint, requestType])
  @@map("api_request_cache")
}

model LlmResponseCache {
  id           Int      @id @default(autoincrement())
  promptType   String   @map("prompt_type") @db.VarChar(50)
  entityKey    String   @map("entity_key") @db.VarChar(100)
  model        String   @db.VarChar(50)
  filePath     String   @map("file_path") @db.VarChar(255)
  fileSize     Int?     @map("file_size")
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([promptType, entityKey, model])
  @@index([promptType])
  @@map("llm_response_cache")
}

// =============================================================================
// USER & AUTH
// =============================================================================

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String
  passwordHash String?     @map("password_hash")
  accessLevel  AccessLevel @default(ANALYST) @map("access_level")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  lastLoginAt  DateTime?   @map("last_login_at")

  focusGroups FocusGroup[]
  focusAreas  FocusArea[]

  @@map("users")
}

// =============================================================================
// ABSTRACT TAXONOMY MODEL
// Replaces hardcoded SuperSector/Sector/SubSector with flexible hierarchy
// =============================================================================

model TaxonomyType {
  id String @id @default(cuid())

  name        String  @unique // "patent-cpc-tech", "product-market"
  displayName String  @map("display_name") // "Technology Classification"
  description String?

  // What this taxonomy classifies
  objectType String @map("object_type") // "patent", "product", "company"

  // Hierarchy configuration
  maxDepth    Int      @map("max_depth") // 3, 4, 5...
  levelLabels String[] @map("level_labels") // ["Super-Sector", "Sector", "Sub-Sector"]

  // How classifications are determined
  ruleType String @map("rule_type") // "cpc-based", "keyword-based", "manual"

  // Status
  isActive  Boolean @default(true) @map("is_active")
  isDefault Boolean @default(false) @map("is_default")
  version   Int     @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  nodes           TaxonomyNode[]
  rules           TaxonomyRule[]
  portfolioGroups PortfolioGroup[]

  @@index([objectType])
  @@index([isDefault])
  @@map("taxonomy_types")
}

model TaxonomyNode {
  id String @id @default(cuid())

  taxonomyTypeId String       @map("taxonomy_type_id")
  taxonomyType   TaxonomyType @relation(fields: [taxonomyTypeId], references: [id])

  // Hierarchy
  parentId String?        @map("parent_id")
  parent   TaxonomyNode?  @relation("NodeHierarchy", fields: [parentId], references: [id])
  children TaxonomyNode[] @relation("NodeHierarchy")

  level Int // 0=root, 1, 2, 3...
  path  String // Materialized path: "VIDEO_STREAMING/video-codec"

  // Identity
  code        String // Unique identifier within taxonomy
  name        String // Display name
  description String?

  // Extensible metadata (cpcPrefixes, damagesTier, etc.)
  metadata Json?

  // Stats (cached)
  childCount  Int @default(0) @map("child_count")
  objectCount Int @default(0) @map("object_count")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  classifications ObjectClassification[]
  rules           TaxonomyRule[]

  @@unique([taxonomyTypeId, code])
  @@index([taxonomyTypeId])
  @@index([parentId])
  @@index([level])
  @@index([path])
  @@map("taxonomy_nodes")
}

model TaxonomyRule {
  id String @id @default(cuid())

  taxonomyTypeId String       @map("taxonomy_type_id")
  taxonomyType   TaxonomyType @relation(fields: [taxonomyTypeId], references: [id])

  targetNodeId String       @map("target_node_id")
  targetNode   TaxonomyNode @relation(fields: [targetNodeId], references: [id])

  ruleType   TaxonomyRuleType @map("rule_type")
  expression String

  priority    Int     @default(0)
  isExclusion Boolean @default(false) @map("is_exclusion")

  scope            TaxonomyRuleScope @default(GLOBAL)
  portfolioGroupId String?           @map("portfolio_group_id")
  portfolioGroup   PortfolioGroup?   @relation(fields: [portfolioGroupId], references: [id])

  isActive    Boolean @default(true) @map("is_active")
  matchCount  Int     @default(0) @map("match_count")
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([taxonomyTypeId])
  @@index([targetNodeId])
  @@index([scope, portfolioGroupId])
  @@map("taxonomy_rules")
}

// =============================================================================
// PORTFOLIO GROUPS
// Scoped collections of portfolios with shared analysis parameters
// =============================================================================

model PortfolioGroup {
  id String @id @default(cuid())

  name        String  @unique
  displayName String  @map("display_name")
  description String?

  // Which taxonomy this group uses
  taxonomyTypeId String       @map("taxonomy_type_id")
  taxonomyType   TaxonomyType @relation(fields: [taxonomyTypeId], references: [id])

  // Tier for tiered analysis strategy
  tier PortfolioGroupTier @default(STANDARD)

  // Analysis parameters (embedded JSON - see PortfolioGroupConfig in design docs)
  config Json

  // Status
  status PortfolioGroupStatus @default(ACTIVE)

  // Recalculation tracking
  lastRecalculatedAt  DateTime?            @map("last_recalculated_at")
  recalculationStatus RecalculationStatus? @map("recalculation_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  members         PortfolioGroupMember[]
  classifications ObjectClassification[]
  rules           TaxonomyRule[]

  @@index([taxonomyTypeId])
  @@index([tier])
  @@index([status])
  @@map("portfolio_groups")
}

model PortfolioGroupMember {
  id String @id @default(cuid())

  portfolioGroupId String         @map("portfolio_group_id")
  portfolioGroup   PortfolioGroup @relation(fields: [portfolioGroupId], references: [id], onDelete: Cascade)

  portfolioId String    @map("portfolio_id")
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now()) @map("added_at")
  addedBy String?  @map("added_by")

  classifiedCount Int @default(0) @map("classified_count")

  @@unique([portfolioGroupId, portfolioId])
  @@index([portfolioGroupId])
  @@index([portfolioId])
  @@map("portfolio_group_members")
}

// =============================================================================
// OBJECT CLASSIFICATION
// Multi-classification support using abstract taxonomy
// =============================================================================

model ObjectClassification {
  id String @id @default(cuid())

  // Scope
  portfolioGroupId String         @map("portfolio_group_id")
  portfolioGroup   PortfolioGroup @relation(fields: [portfolioGroupId], references: [id], onDelete: Cascade)

  // Object being classified (polymorphic)
  objectType String @map("object_type") // "patent", "product"
  objectId   String @map("object_id")

  // Classification target
  taxonomyNodeId String       @map("taxonomy_node_id")
  taxonomyNode   TaxonomyNode @relation(fields: [taxonomyNodeId], references: [id])

  // Privileged association rank (1=primary, 2=secondary, etc.)
  associationRank Int @map("association_rank")

  // Scoring
  weight     Float  @default(1.0)
  confidence Float?

  // Provenance
  sourceCodes          String[] @map("source_codes")
  inventiveSourceCount Int      @default(0) @map("inventive_source_count")

  // Assignment metadata
  assignedAt    DateTime @default(now()) @map("assigned_at")
  assignedBy    String   @map("assigned_by")
  configVersion Int      @map("config_version")

  @@unique([portfolioGroupId, objectId, associationRank])
  @@index([portfolioGroupId])
  @@index([objectType, objectId])
  @@index([taxonomyNodeId])
  @@index([associationRank])
  @@map("object_classifications")
}

// =============================================================================
// COMPANIES, PORTFOLIOS & AFFILIATES
// =============================================================================

model Company {
  id          String  @id @default(cuid())
  name        String  @unique
  displayName String  @map("display_name")
  description String?
  website     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  affiliates    Affiliate[]
  portfolios    Portfolio[]
  competitorsOf CompetitorRelationship[] @relation("CompetitorFrom")
  competitorTo  CompetitorRelationship[] @relation("CompetitorTo")

  @@map("companies")
}

model CompetitorRelationship {
  id              String                    @id @default(cuid())
  companyId       String                    @map("company_id")
  company         Company                   @relation("CompetitorFrom", fields: [companyId], references: [id], onDelete: Cascade)
  competitorId    String                    @map("competitor_id")
  competitor      Company                   @relation("CompetitorTo", fields: [competitorId], references: [id], onDelete: Cascade)
  sectors         String[]
  discoverySource CompetitorDiscoverySource @default(MANUAL) @map("discovery_source")
  strength        Float?
  notes           String?
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  @@unique([companyId, competitorId])
  @@index([companyId])
  @@index([competitorId])
  @@map("competitor_relationships")
}

model Portfolio {
  id             String  @id @default(cuid())
  name           String  @unique
  displayName    String  @map("display_name")
  description    String?
  companyId      String  @map("company_id")
  company        Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  patentCount    Int     @default(0) @map("patent_count")
  affiliateCount Int     @default(0) @map("affiliate_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patents          PortfolioPatent[]
  scoreSnapshots   ScoreSnapshot[]
  batchJobs        BatchJob[]
  groupMemberships PortfolioGroupMember[]
  unifiedSnapshots UnifiedSnapshot[]
  sectorRules      SectorRule[] // Legacy relation for migration

  @@index([companyId])
  @@map("portfolios")
}

model Affiliate {
  id           String             @id @default(cuid())
  companyId    String             @map("company_id")
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  displayName  String             @map("display_name")
  isActive     Boolean            @default(true) @map("is_active")
  acquiredYear Int?               @map("acquired_year")
  notes        String?
  description  String?
  parentId     String?            @map("parent_id")
  parent       Affiliate?         @relation("AffiliateHierarchy", fields: [parentId], references: [id])
  children     Affiliate[]        @relation("AffiliateHierarchy")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  patterns     AffiliatePattern[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("affiliates")
}

model AffiliatePattern {
  id          String    @id @default(cuid())
  affiliateId String    @map("affiliate_id")
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  pattern     String
  isExact     Boolean   @default(false) @map("is_exact")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([affiliateId, pattern])
  @@index([affiliateId])
  @@map("affiliate_patterns")
}

model PortfolioPatent {
  id          String       @id @default(cuid())
  portfolioId String       @map("portfolio_id")
  portfolio   Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  patentId    String       @map("patent_id")
  patent      Patent       @relation(fields: [patentId], references: [patentId], onDelete: Cascade)
  source      PatentSource @default(CANDIDATES_FILE)
  addedAt     DateTime     @default(now()) @map("added_at")

  @@unique([portfolioId, patentId])
  @@index([portfolioId])
  @@index([patentId])
  @@map("portfolio_patents")
}

// =============================================================================
// PATENT DATA
// Core patent entity with both legacy and new abstract classification fields
// =============================================================================

model Patent {
  id         String   @id @default(cuid())
  patentId   String   @unique @map("patent_id")
  title      String   @default("")
  abstract   String?  @db.Text
  grantDate  String?  @map("grant_date")
  filingDate String?  @map("filing_date")
  assignee   String   @default("")
  inventors  String[] @default([])

  // Computed/derived fields
  forwardCitations Int     @default(0) @map("forward_citations")
  remainingYears   Float?  @map("remaining_years")
  isExpired        Boolean @default(false) @map("is_expired")
  baseScore        Float?  @map("base_score")

  // Affiliate matching
  affiliate String?

  // LEGACY pragmatic fields (kept for backward compatibility during migration)
  // TODO: Deprecate after migration to abstract model
  superSector          String? @map("super_sector")
  primarySector        String? @map("primary_sector")
  primaryCpc           String? @map("primary_cpc")
  primarySubSectorId   String? @map("primary_sub_sector_id")
  primarySubSectorName String? @map("primary_sub_sector_name")

  // NEW pragmatic fields (abstract level names, synced from ObjectClassification)
  primaryLevel1       String? @map("primary_level1")
  primaryLevel2       String? @map("primary_level2")
  primaryLevel3       String? @map("primary_level3")
  primaryLevel1NodeId String? @map("primary_level1_node_id")
  primaryLevel2NodeId String? @map("primary_level2_node_id")
  primaryLevel3NodeId String? @map("primary_level3_node_id")

  // Source code stats
  inventiveSourceCount  Int? @map("inventive_source_count")
  additionalSourceCount Int? @map("additional_source_count")
  mappedSourceCount     Int? @map("mapped_source_count")
  unmappedSourceCount   Int? @map("unmapped_source_count")

  // Multi-classification indicators
  potentialNodeCount Int?     @map("potential_node_count")
  crossLevel1        Boolean? @map("cross_level1")

  // Enrichment tracking
  hasLlmData           Boolean @default(false) @map("has_llm_data")
  hasCitationData      Boolean @default(false) @map("has_citation_data")
  hasProsecutionData   Boolean @default(false) @map("has_prosecution_data")
  hasXmlData           Boolean @default(false) @map("has_xml_data")
  hasIprData           Boolean @default(false) @map("has_ipr_data")
  hasFamilyData        Boolean @default(false) @map("has_family_data")
  hasProsecutionDetail Boolean @default(false) @map("has_prosecution_detail")

  // Quarantine
  isQuarantined   Boolean @default(false) @map("is_quarantined")
  quarantine      Json?
  patentIdNumeric Int?    @map("patent_id_numeric")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  portfolios          PortfolioPatent[]
  cpcCodes            PatentCpc[]
  citations           PatentCitationAnalysis?
  prosecution         PatentProsecution?
  prosecutionTimeline ProsecutionTimeline?
  scores              PatentScore[]
  compositeScores     PatentCompositeScore[]

  @@index([primarySector])
  @@index([superSector])
  @@index([primaryLevel1])
  @@index([primaryLevel2])
  @@index([assignee])
  @@index([baseScore])
  @@index([isExpired])
  @@index([isQuarantined])
  @@map("patents")
}

model PatentCpc {
  id          String  @id @default(cuid())
  patentId    String  @map("patent_id")
  patent      Patent  @relation(fields: [patentId], references: [patentId], onDelete: Cascade)
  cpcCode     String  @map("cpc_code")
  isInventive Boolean @default(false) @map("is_inventive")

  @@unique([patentId, cpcCode])
  @@index([patentId])
  @@index([cpcCode])
  @@map("patent_cpc_codes")
}

model PatentCitationAnalysis {
  id                       String   @id @default(cuid())
  patentId                 String   @unique @map("patent_id")
  patent                   Patent   @relation(fields: [patentId], references: [patentId], onDelete: Cascade)
  competitorCitations      Int      @default(0) @map("competitor_citations")
  affiliateCitations       Int      @default(0) @map("affiliate_citations")
  neutralCitations         Int      @default(0) @map("neutral_citations")
  competitorNames          String[] @map("competitor_names")
  adjustedForwardCitations Float?   @map("adjusted_forward_citations")
  competitorDensity        Float?   @map("competitor_density")
  classifiedAt             DateTime @default(now()) @map("classified_at")

  @@map("patent_citation_analyses")
}

model PatentProsecution {
  id                      String  @id @default(cuid())
  patentId                String  @unique @map("patent_id")
  patent                  Patent  @relation(fields: [patentId], references: [patentId], onDelete: Cascade)
  applicationNumber       String? @map("application_number")
  officeActionsCount      Int     @default(0) @map("office_actions_count")
  nonFinalRejections      Int     @default(0) @map("non_final_rejections")
  finalRejections         Int     @default(0) @map("final_rejections")
  allowances              Int     @default(0)
  prosecutionQualityScore Int?    @map("prosecution_quality_score")
  prosecutionCategory     String? @map("prosecution_category")

  @@map("patent_prosecution")
}

model PatentScore {
  id          String   @id @default(cuid())
  patentId    String   @map("patent_id")
  patent      Patent   @relation(fields: [patentId], references: [patentId], onDelete: Cascade)
  fieldName   String   @map("field_name")
  displayName String?  @map("display_name")
  rating      Int?
  floatValue  Float?   @map("float_value")
  textValue   String?  @map("text_value")
  reasoning   String?  @db.Text
  source      String   @default("llm")
  templateId  String?  @map("template_id")
  llmModel    String?  @map("llm_model")
  scoredAt    DateTime @default(now()) @map("scored_at")
  isStale     Boolean  @default(false) @map("is_stale")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([patentId, fieldName])
  @@index([patentId])
  @@index([fieldName])
  @@index([rating])
  @@map("patent_scores")
}

model PatentCompositeScore {
  id         String   @id @default(cuid())
  patentId   String   @map("patent_id")
  patent     Patent   @relation(fields: [patentId], references: [patentId], onDelete: Cascade)
  scoreName  String   @map("score_name")
  value      Float
  rank       Int?
  percentile Float?
  config     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([patentId, scoreName])
  @@index([patentId])
  @@index([scoreName])
