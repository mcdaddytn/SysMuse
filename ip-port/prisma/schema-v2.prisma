  objectType  String?  @map("object_type")
  objectId    String?  @map("object_id")
  result      Json
  resultType  String   @map("result_type")
  fieldValues Json?    @map("field_values")
  model       String?
  tokensUsed  Int?     @map("tokens_used")
  promptSent  String?  @map("prompt_sent") @db.Text
  executedAt  DateTime @map("executed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([entityType, entityId, objectId])
  @@index([templateId])
  @@index([jobId])
  @@map("entity_analysis_results")
}

// =============================================================================
// PATENT FAMILY EXPLORATION
// =============================================================================

model PatentFamilyExploration {
  id                  String         @id @default(cuid())
  seedPatentId        String         @map("seed_patent_id")
  seedPatentIds       String[]       @default([]) @map("seed_patent_ids")
  name                String?
  description         String?
  maxAncestorDepth    Int            @default(2) @map("max_ancestor_depth")
  maxDescendantDepth  Int            @default(2) @map("max_descendant_depth")
  includeSiblings     Boolean        @default(true) @map("include_siblings")
  includeCousins      Boolean        @default(false) @map("include_cousins")
  limitToSectors      String[]       @map("limit_to_sectors")
  limitToCpcPrefixes  String[]       @map("limit_to_cpc_prefixes")
  limitToFocusAreas   String[]       @map("limit_to_focus_areas")
  requireInPortfolio  Boolean        @default(false) @map("require_in_portfolio")
  version             Int            @default(1)
  weights             Json?
  membershipThreshold Float?         @map("membership_threshold")
  expansionThreshold  Float?         @map("expansion_threshold")
  portfolioWeighting  Json?          @map("portfolio_weighting")
  seedAggregate       Json?          @map("seed_aggregate")
  currentGeneration   Int            @default(0) @map("current_generation")
  memberCount         Int            @default(0) @map("member_count")
  candidateCount      Int            @default(0) @map("candidate_count")
  status              WorkflowStatus @default(PENDING)
  discoveredCount     Int            @default(0) @map("discovered_count")
  errorMessage        String?        @map("error_message")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  members        PatentFamilyMember[]
  expansionSteps PatentFamilyExpansionStep[]

  @@index([seedPatentId])
  @@map("patent_family_explorations")
}

model PatentFamilyMember {
  id               String                  @id @default(cuid())
  explorationId    String                  @map("exploration_id")
  exploration      PatentFamilyExploration @relation(fields: [explorationId], references: [id], onDelete: Cascade)
  patentId         String                  @map("patent_id")
  status           String                  @default("candidate")
  relationToSeed   String                  @map("relation_to_seed")
  generationDepth  Int                     @map("generation_depth")
  discoveredVia    String[]                @default([]) @map("discovered_via")
  discoveredAtStep Int?                    @map("discovered_at_step")
  dimensionScores  Json?                   @map("dimension_scores")
  compositeScore   Float?                  @map("composite_score")
  dataCompleteness Float?                  @map("data_completeness")
  inPortfolio      Boolean                 @default(false) @map("in_portfolio")
  title            String?
  assignee         String?
  sector           String?
  superSector      String?                 @map("super_sector")
  filingDate       String?                 @map("filing_date")
  remainingYears   Float?                  @map("remaining_years")
  isCompetitor     Boolean                 @default(false) @map("is_competitor")
  competitorName   String?                 @map("competitor_name")
  createdAt        DateTime                @default(now()) @map("created_at")

  @@unique([explorationId, patentId])
  @@index([explorationId])
  @@index([explorationId, status])
  @@index([compositeScore])
  @@index([patentId])
  @@map("patent_family_members")
}

model PatentFamilyExpansionStep {
  id                  String                  @id @default(cuid())
  explorationId       String                  @map("exploration_id")
  exploration         PatentFamilyExploration @relation(fields: [explorationId], references: [id], onDelete: Cascade)
  stepNumber          Int                     @map("step_number")
  direction           String
  generationDepth     Int                     @map("generation_depth")
  candidatesEvaluated Int                     @map("candidates_evaluated")
  autoIncluded        Int                     @default(0) @map("auto_included")
  expansionZone       Int                     @default(0) @map("expansion_zone")
  autoRejected        Int                     @default(0) @map("auto_rejected")
  userAccepted        Int                     @default(0) @map("user_accepted")
  userExcluded        Int                     @default(0) @map("user_excluded")
  weightsUsed         Json                    @map("weights_used")
  thresholdsUsed      Json                    @map("thresholds_used")
  createdAt           DateTime                @default(now()) @map("created_at")

  @@index([explorationId])
  @@map("patent_family_expansion_steps")
}

// =============================================================================
// LEGACY MODELS (kept for migration, will be removed after data migration)
// =============================================================================

model SuperSector {
  id String @id @default(cuid())

  name        String  @unique // e.g., "SECURITY"
  displayName String  @map("display_name") // e.g., "Security"
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sectors Sector[]

  @@map("super_sectors")
}

model Sector {
  id String @id @default(cuid())

  name        String  @unique // e.g., "video-codec"
  displayName String  @map("display_name") // e.g., "Video Codec"
  description String?

  superSectorId String?      @map("super_sector_id")
  superSector   SuperSector? @relation(fields: [superSectorId], references: [id])

  // CPC mapping (from sectorMappings config)
  cpcPrefixes String[] @map("cpc_prefixes")

  // Metadata
  damagesTier   String? @map("damages_tier") // "Very High", "High", "Medium", "Low"
  damagesRating Int?    @map("damages_rating") // Numeric 1-4 (Low=1, Medium=2, High=3, Very High=4)
  facets        Json? // Scoring multipliers from sector-facets.json
  patentCount   Int     @default(0) @map("patent_count") // Cached count

  // Sector management — targets for refactoring
  targetMinSize Int? @map("target_min_size")
  targetMaxSize Int? @map("target_max_size") // Default guidance: 500

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  rules      SectorRule[]
  subSectors SubSector[]

  @@index([superSectorId])
  @@map("sectors")
}

model SectorRule {
  id       String @id @default(cuid())
  sectorId String @map("sector_id")
  sector   Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  ruleType   SectorRuleType @default(CPC_PREFIX) @map("rule_type")
  expression String // CPC prefix, keyword, phrase, boolean expr

  priority    Int     @default(0) // Higher = evaluated first
  isExclusion Boolean @default(false) @map("is_exclusion")

  scope       SectorRuleScope @default(LIBRARY)
  portfolioId String?         @map("portfolio_id") // Non-null for portfolio overrides
  portfolio   Portfolio?      @relation(fields: [portfolioId], references: [id])

  description String?
  isActive    Boolean @default(true) @map("is_active")
  matchCount  Int     @default(0) @map("match_count")

  promotedFrom String?   @map("promoted_from")
  promotedAt   DateTime? @map("promoted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sectorId])
  @@index([ruleType])
  @@index([scope, portfolioId])
  @@map("sector_rules")
}

enum SectorRuleType {
  CPC_PREFIX // CPC code starts with expression
  CPC_SUBGROUP // Exact CPC subgroup match
  KEYWORD // Title/abstract contains keyword
  PHRASE // Exact phrase match
  KEYWORD_AND // All space-separated keywords must appear
  BOOLEAN // Complex boolean expression
}

enum SectorRuleScope {
  LIBRARY // Universal rule (all portfolios)
  PORTFOLIO // Portfolio-specific override
}

model SubSector {
  id String @id @default(cuid())

  // Parent sector relationship
  sectorId String @map("sector_id")
  sector   Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  // Identity
  name        String // e.g., "hypervisors-2021" or "H04L45/586"
  displayName String  @map("display_name")
  description String?

  // Primary grouping criterion
  groupingType SubSectorGroupingType @default(CPC_SUBGROUP) @map("grouping_type")

  // CPC-based grouping (most common)
  cpcCode   String? @map("cpc_code") // Full CPC subgroup code
  cpcPrefix String? @map("cpc_prefix") // Or a prefix pattern

  // Date-based grouping (for splitting large CPC groups)
  dateRangeStart String? @map("date_range_start") // YYYY or YYYY-MM-DD
  dateRangeEnd   String? @map("date_range_end")

  // Combined: CPC + date (for secondary splits)
  parentCpcCode String? @map("parent_cpc_code") // If date-split from a CPC group

  // Status
  status SubSectorStatus @default(PROSPECTIVE)

  // Cached stats
  patentCount Int @default(0) @map("patent_count")

  // Flags for user attention
  needsReview  Boolean @default(false) @map("needs_review") // Above threshold, needs intervention
  reviewReason String? @map("review_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sectorId, name])
  @@index([sectorId])
  @@index([status])
  @@index([cpcCode])
  @@map("sub_sectors")
}

enum SubSectorGroupingType {
  CPC_SUBGROUP // Full CPC subgroup code (e.g., H04L63/1416)
  CPC_GROUP // CPC group (e.g., H04L63/14)
  CPC_PREFIX // CPC prefix pattern
  DATE_RANGE // Date-based split of a CPC group
  CUSTOM // User-defined custom grouping
}

enum SubSectorStatus {
  PROSPECTIVE // Generated but not applied
  APPLIED // Applied to patent assignments
  ARCHIVED // No longer active
}
